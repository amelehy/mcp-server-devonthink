{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"strict": true,
		"isolatedModules": true,
		"incremental": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"skipLibCheck": true
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["./dist", "./node_modules", "./tests"]
}
